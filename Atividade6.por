programa {
  funcao inicio() { 
    inteiro NumeroA, NumeroB
    escreva ("Me informe o valor dos dois numeros ")
    leia (NumeroA)
    leia (NumeroB)
      
    se (NumeroA > NumeroB){
      escreva ("O maior numero e ", NumeroA)
    }
    senao {
      escreva ("O maior numero e ", NumeroB)
    }
    
  }
}
